#!/bin/sh
set -e

echo "[pre-push] push changeset guard"

# Always run from repo root.
repo="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
if [ -n "$repo" ]; then cd "$repo"; fi

# If no upstream, don't guess. Skip (consistent with earlier behavior).
upstream="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")"
if [ -z "$upstream" ]; then
  echo "[pre-push] no upstream -> skip checks"
  exit 0
fi

# If nothing to push, skip.
ahead="$(git rev-list --count "$upstream"..HEAD 2>/dev/null || echo "0")"
if [ "$ahead" = "0" ]; then
  echo "[pre-push] nothing to push -> skip checks"
  exit 0
fi

# Base is origin/main if present, otherwise use upstream's remote tip.
base="origin/main"
git rev-parse --verify "$base" >/dev/null 2>&1 || base="$upstream"

# File list for the push changeset guard (approx; good enough for "size" & risk routing).
files="$(git diff --name-only --diff-filter=ACMR "$base"...HEAD 2>/dev/null || echo "")"

# Count files (portable-ish).
count=0
if [ -n "$files" ]; then
  # shellcheck disable=SC2039
  for _f in $files; do count=$((count + 1)); done
fi

max=250
echo "[pre-push] Push changeset file count = $count; max = $max; base = $base"

if [ "$count" -gt "$max" ]; then
  echo "[pre-push] Push changeset TOO LARGE ($count > $max)"
  exit 1
fi

echo "[pre-push] Push changeset size OK ($count <= $max) vs $base"
echo "[pre-push] smart dispatcher"

# Risk classification: high-risk -> green:ci, low-risk -> green:fast
is_high_risk=0

# shellcheck disable=SC2039
for f in $files; do
  case "$f" in
    engine/*|api/*|ci/*|test/*|scripts/*|docs/ENGINE_*|ENGINE_CONTRACT.md|schema.sql|docs/checksums.sha256)
      is_high_risk=1
      ;;
    package.json|package-lock.json|tsconfig*.json|.github/*|githooks/*|scripts/hooks/*)
      is_high_risk=1
      ;;
    *)
      ;;
  esac
done

if [ "$is_high_risk" -eq 1 ]; then
  echo "[pre-push] engine-risk change -> green:ci"
  npm run green:ci
else
  echo "[pre-push] low-risk change -> green:fast"
  npm run green:fast
fi

echo "[pre-push] OK"
