{
  "name": "kolosseum",
  "private": true,
  "version": "0.1.18",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test",
    "guard:constraints": "node ci/guards/no_legacy_constraints.mjs",
    "guard:version": "node scripts/version-gate.mjs",
    "lint": "node ci/guards/repo_contract.mjs && node ci/guards/engine_contract_guard.mjs && node ci/guards/golden_manifest_guard.mjs && node ci/guards/golden_outputs_guard.mjs && node ci/scripts/spine_guard.mjs && node ci/scripts/sha256_guard.mjs && node ci/scripts/schema_guard.mjs && npm run test:ci",
    "ci": "npm run guard:constraints && npm run guard:version && npm run lint && npm test && npm run e2e:golden",
    "hash:write": "node ci/scripts/write_checksums.mjs",
    "run:cli": "node dist/cli/src/main.js",
    "db:schema": "node scripts/apply-schema.mjs",
    "start": "node dist/src/server.js",
    "smoke:fresh": "node scripts/ps-runner.mjs --file scripts/smoke-api.ps1 -- -Mode fresh",
    "smoke:idem": "node scripts/ps-runner.mjs --file scripts/smoke-api.ps1 -- -Mode idempotent",
    "dev:check": "npm run ci && npm run db:schema",
    "release:prepare": "node scripts/ps-runner.mjs --file scripts/release-prepare.ps1",
    "release:tag": "node scripts/ps-runner.mjs --file scripts/tag-release.ps1",
    "e2e:golden": "node ci/scripts/e2e_golden.mjs",
    "pipeline:run": "node dist/src/run_pipeline_cli.js",
    "golden:manifest": "node ci/scripts/write_golden_manifest.mjs",
    "golden:outputs": "node ci/scripts/write_golden_outputs.mjs",
    "golden:update": "node ci/scripts/golden_update.mjs",
    "test:ci": "node test/ci_stable_stringify.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "pg": "^8.17.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.16.0",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist/",
    "registries/",
    "ci/schemas/",
    "schema.sql",
    "ENGINE_CONTRACT.md"
  ]
}
