{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kolosseum://registries/program.registry.schema.json",
  "title": "Program Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "entries"],
  "properties": {
    "registry_id": {
      "type": "string",
      "const": "program"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "program_id", "intent"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "program_id": {
            "type": "string",
            "minLength": 1
          },
          "intent": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
