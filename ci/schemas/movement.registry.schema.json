{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kolosseum://registries/movement.registry.schema.json",
  "title": "Movement Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "entries"],
  "properties": {
    "registry_id": { "type": "string", "const": "movement" },
    "version": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["movement_id", "equipment_vocab", "joint_stress_tags_vocab"],
        "properties": {
          "movement_id": { "type": "string", "minLength": 1 },
          "equipment_vocab": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "joint_stress_tags_vocab": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
