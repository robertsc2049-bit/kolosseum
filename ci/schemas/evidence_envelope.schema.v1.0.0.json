{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kolosseum:evidence_envelope.schema.v1.0.0",
  "title": "Kolosseum Evidence Envelope (v1.0.0)",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "engine", "inputs", "artifacts", "validations"],
  "properties": {
    "contract": {
      "type": "string",
      "const": "kolosseum:evidence_envelope@1"
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "node"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1 }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_sha256", "constraints_sha256", "registry_bundle_sha256", "schema_sha256s"],
      "properties": {
        "request_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "constraints_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "registry_bundle_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "schema_sha256s": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_outputs"],
      "properties": {
        "phase_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "name", "sha256"],
            "properties": {
              "phase": { "type": "integer", "minimum": 1, "maximum": 99 },
              "name": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
              "path": { "type": "string" }
            }
          }
        }
      }
    },
    "validations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guards"],
      "properties": {
        "guards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "result"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "result": { "type": "string", "enum": ["pass", "fail", "skip"] },
              "detail": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
