{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kolosseum.registry_seal_manifest.v1",
  "title": "Kolosseum Registry Seal Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "manifest_version",
    "seal_scope",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": "kolosseum.registry_seal_manifest.v1"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "seal_scope": {
      "const": "registry_bundle"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}