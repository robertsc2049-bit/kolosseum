{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase1Input v1.0.0 (starter)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consent_granted",
    "engine_version",
    "enum_bundle_version",
    "phase1_schema_version",
    "actor_type",
    "execution_scope",
    "activity_id",
    "nd_mode",
    "instruction_density",
    "exposure_prompt_density",
    "bias_mode"
  ],
  "properties": {
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraints_version"],
      "properties": {
        "constraints_version": { "type": "string", "const": "1.0.0" },

        "goal_id": {
          "type": "string",
          "enum": ["strength", "hypertrophy", "general_fitness", "rehab", "sport_performance"]
        },

        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "days_per_week": { "type": "integer", "minimum": 1, "maximum": 7 },
            "session_timebox_minutes": { "type": "integer", "minimum": 10, "maximum": 240 }
          }
        },

        "preferences": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "consistency_variety": { "type": "string", "enum": ["consistency", "variety"] },
            "volume_cap": { "type": "string", "enum": ["low", "standard", "high"] }
          }
        },

        "pain_probe_state": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "has_active_pain": { "type": "boolean" },
            "active_pain_sites": {
              "type": "array",
              "items": { "type": "string" }
            },
            "probe_consent": { "type": "boolean" }
          }
        },

        "avoid_joint_stress_tags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },

        "banned_equipment": {
          "type": "array",
          "items": { "type": "string" }
        },

        "available_equipment": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },

    "consent_granted": { "type": "boolean", "const": true },

    "engine_version": { "type": "string", "const": "EB2-1.0.0" },
    "enum_bundle_version": { "type": "string", "const": "EB2-1.0.0" },
    "phase1_schema_version": { "type": "string", "const": "1.0.0" },

    "actor_type": { "type": "string", "enum": ["athlete", "coach", "org_admin"] },
    "execution_scope": { "type": "string", "enum": ["individual", "coach_managed", "org_managed"] },

    "governing_authority_id": { "type": "string" },

    "activity_id": { "type": "string", "minLength": 1 },
    "sport_role_id": { "type": "string" },

    "nd_mode": { "type": "boolean" },

    "instruction_density": {
      "type": "string",
      "enum": ["minimal", "standard", "detailed"]
    },

    "exposure_prompt_density": {
      "type": "string",
      "enum": ["minimal", "standard", "detailed"]
    },

    "bias_mode": {
      "type": "string",
      "enum": ["none", "consistency", "variety"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "execution_scope": { "enum": ["coach_managed", "org_managed"] } },
        "required": ["execution_scope"]
      },
      "then": { "required": ["governing_authority_id"] }
    }
  ]
}