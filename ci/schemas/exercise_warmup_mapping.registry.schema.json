{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercise Warm-up Mapping Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_header",
    "entries"
  ],
  "properties": {
    "registry_header": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "document_id",
        "document_title",
        "document_type",
        "document_version",
        "status",
        "engine_compatibility",
        "scope_class",
        "rewrite_policy"
      ],
      "properties": {
        "document_id": { "type": "string", "minLength": 1 },
        "document_title": { "type": "string", "minLength": 1 },
        "document_type": { "type": "string", "minLength": 1 },
        "document_version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "engine_compatibility": { "type": "string", "minLength": 1 },
        "scope_class": { "type": "string", "minLength": 1 },
        "rewrite_policy": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lane",
          "warm_up_ids"
        ],
        "properties": {
          "lane": {
            "type": "string",
            "minLength": 1
          },
          "warm_up_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}