{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kolosseum://registries/activity.registry.schema.json",
  "title": "Activity Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_id", "version", "entries"],
  "properties": {
    "registry_id": { "type": "string", "const": "activity" },
    "version": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["activity_id", "stimulus_intents"],
        "properties": {
          "activity_id": { "type": "string", "minLength": 1 },
          "stimulus_intents": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
