# Enforce LF for repo-critical text
* text=auto eol=lf

# Code / scripts
*.ps1  text eol=lf
*.psm1 text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Hook files (no extension)
scripts/hooks/* text eol=lf

# Treat these as binary (never normalize)
*.docx binary
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.zip  binary