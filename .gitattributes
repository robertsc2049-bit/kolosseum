# =========================================
# Global: enforce LF everywhere
# =========================================
* text=auto eol=lf

# =========================================
# Explicit text formats (belt + braces)
# =========================================
*.js        text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.ps1       text eol=lf
*.sql       text eol=lf

# =========================================
# Binary files (never touch line endings)
# =========================================
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary