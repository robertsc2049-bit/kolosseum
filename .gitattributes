# Normalize text files to LF in the repo
* text=auto eol=lf

# Explicit text types
*.md  text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.ts  text eol=lf
*.mjs text eol=lf
*.js  text eol=lf
*.ps1 text eol=lf
*.sql text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary