# Force LF in this repo (Windows-safe, CI-safe)
* text=auto eol=lf

# Explicitly pin critical text formats
*.json  text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.md    text eol=lf
*.ps1   text eol=lf

