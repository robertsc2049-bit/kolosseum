# Default to LF in repo
* text=auto eol=lf

# Explicit types
*.mjs text eol=lf
*.ts  text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md  text eol=lf
*.ps1 text eol=lf
*.sql text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
# Treat Office docs as binary (never normalize/convert)
*.docx binary
*.doc  binary
*.pptx binary
*.xlsx binary

# --- Line endings: enforce LF for scripts (Windows-safe, Git Bash-friendly) ---
*.sh   text eol=lf
*.mjs  text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.ps1  text eol=lf
